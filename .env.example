# =============================================================================
# Twilio — WhatsApp Business API
# =============================================================================
ACCOUNT_SID=""
AUTH_TOKEN=""
WHATSAPP_NUMBER=""            # e.g. whatsapp:+14155238886
MESSAGING_SERVICE_SID=""

# =============================================================================
# LLM Inference
# =============================================================================
OPENROUTER_API_KEY=""         # https://openrouter.ai/

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=""               # MongoDB connection string, e.g. mongodb+srv://...

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=""                 # Random secret for JWT signing (use: openssl rand -hex 32)

# =============================================================================
# Application
# =============================================================================
BASE_URL=""                   # Public-facing base URL, e.g. https://api.example.com
SPECIAL_WORK_APPLICATION_ID=""
LEAVE_APPLICATION_ID=""
DEFAULT_COUNTRY_CODE="852"    # Hong Kong dial code
DEFAULT_OCCUPATION="worker"

# =============================================================================
# Redis
# =============================================================================
KEY_NAME="erp-assistant"
REDIS_KEY_PREFIX="erp-assistant"
REDIS_MODE="local"            # "local" or "remote"
REDIS_HOST="redis"            # Docker service name or hostname
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# Temporal.io
# =============================================================================
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE_NAME="erp-assistant-task-queue"
TEMPORAL_ADDRESS=""           # e.g. temporal:7233 (Docker) or localhost:7233

# =============================================================================
# Google Cloud Document AI — OCR processors
# Each value is a path to a service account JSON file (never commit these files)
# =============================================================================
NATIONAL_ID_DOCUMENTAI_CREDENTIALS=""
BANKING_CARD_DOCUMENTAI_CREDENTIALS=""
MATERIAL_OCR_DOCUMENTAI_CREDENTIALS=""
WORK_PERMIT_DOCUMENTAI_CREDENTIALS=""
